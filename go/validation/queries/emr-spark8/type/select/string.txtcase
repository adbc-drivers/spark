// part: setup_query

CREATE TABLE test_string (
    idx INTEGER,
    res VARCHAR(1000)
) USING parquet LOCATION 's3://{bucket}/emr/type/select/{uuid}';

INSERT INTO test_string
SELECT 1, 'hello' UNION ALL
SELECT 2, '' UNION ALL
SELECT 3, CONCAT('Special chars: !@#$%^&*()_+{}|:"<>?~`-=[]', CHR(92), ';', CHR(39), ',./') UNION ALL
SELECT 4, 'Unicode: 你好, Привет, こんにちは, สวัสดี' UNION ALL
SELECT 5, NULL;
