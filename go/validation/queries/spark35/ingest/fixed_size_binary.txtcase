// part: metadata

# https://issues.apache.org/jira/browse/SPARK-28474
# Spark's Thrift protocol converts binary to UTF-8 strings, replacing bytes
# greater than 0x7F with U+FFFD.
skip = "Spark Thrift corrupts non-UTF-8 binary data (SPARK-28474)"

[tags]
sql-type-name = "BINARY"
